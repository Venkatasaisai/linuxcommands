GIT COMMANDS
git init              # Create a new Git repository
git clone <repository_url>    # Download source code repositor
git status                  # Check file status
git branch                  # Show/Create branches
git checkout <branch>       # Switch branch
git checkout -b <branch>    # Create and switch to a new branch
git diff                    # View code change
git add .                   # Add changes to staging
git commit -m "message"     # Save changes locally
git log --oneline           # View commit history
git log                 #shows commit history like id, authorname, date, msg 
git show                    # Show details of a commit
git pull                    # Get latest changes from remote
git fetch                   # Download changes without merging
git merge <branch>          # Merge branch changes
git push                    # Upload changes to remote repository
git stash                   # Temporarily save uncommitted changes
git stash pop               # Restore stashed changes
git remote -v              # Show remote repository URLs
